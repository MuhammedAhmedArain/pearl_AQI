# Pearls AQI Predictor - Environment Variables Template
#
# Copy this file to .env and fill in your own credentials.
# Never commit real API keys or tokens.

# OpenWeatherMap API
# Sign up at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# AQICN API (optional fallback)
# Sign up at https://aqicn.org/data-platform/token/
AQICN_API_KEY=demo

# Hopsworks Feature Store + Model Registry
# Sign up at https://app.hopsworks.ai
HOPSWORKS_API_KEY=your_hopsworks_api_key_here
HOPSWORKS_PROJECT=pearlsAQI
HOPSWORKS_HOST=eu-west.cloud.hopsworks.ai

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Set true in production automation to require Hopsworks Feature Store and Model Registry.
# Keep false for local development demos that use local artifacts when credentials are absent.
REQUIRE_FEATURE_STORE=false

# Logging
LOG_LEVEL=INFO
