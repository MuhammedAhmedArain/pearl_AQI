# ══════════════════════════════════════════════════════════════
# Pearls AQI Predictor — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# ── OpenWeatherMap API ────────────────────────────────────────
# Sign up free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=473851343bf5ec1b96136e2d83f05d13

# ── AQICN API (optional fallback) ────────────────────────────
# Sign up at: https://aqicn.org/data-platform/token/
AQICN_API_KEY=demo

# ── Hopsworks Feature Store + Model Registry ──────────────────
# Sign up free at: https://app.hopsworks.ai
# Steps:
#   1. Login to Hopsworks
#   2. Open your project "pearlsAQI"
#   3. Click avatar (top-right) -> Settings -> API Keys
#   4. Create a key and paste below
HOPSWORKS_API_KEY=oTFRQFgX8KksQIl5.zbFTln5UgJ8xsFOKe0QjbiYwKiBCHJklPUlMrluo8sODjBd7eXjB392XacUqvuBU
HOPSWORKS_PROJECT=pearlsAQI
HOPSWORKS_HOST=c.app.hopsworks.ai

# ── FastAPI Server Config ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
